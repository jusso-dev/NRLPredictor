APP_NAME="NRL Try Predictor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nrl_expert
DB_USERNAME=nrl
DB_PASSWORD=nrl_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Long-lived Anthropic API token used by the Claude Agent service.
CLAUDE_AGENT_TOKEN=
CLAUDE_AGENT_MODEL=claude-sonnet-4-5
CLAUDE_AGENT_MAX_TURNS=12

# Shared secret between Laravel and the Python Flask agent service.
# Generate with: openssl rand -hex 32
CLAUDE_AGENT_INTERNAL_SECRET=

# Docker-compose-internal URLs. Override these only if you run without compose.
CLAUDE_AGENT_SERVICE_URL=http://agent:5000
CLAUDE_AGENT_CALLBACK_URL=http://app:8000

# The Odds API key (https://the-odds-api.com). Enables bookmaker odds + player props.
# Optional — leave blank to skip odds enrichment.
ODDS_API_KEY=

# MySQL root password — only consumed by docker-compose for the MySQL container.
# Change from the default before deploying anywhere public.
DB_ROOT_PASSWORD=root_secret
